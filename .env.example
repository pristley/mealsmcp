# Optional Configuration for Meals MCP Server
# Copy this file to .env and modify values as needed
# All values are optional and have sensible defaults

# TheMealDB API base URL
# Default: https://www.themealdb.com/api/json/v1/1
# MEALDB_API_URL=https://www.themealdb.com/api/json/v1/1

# HTTP request timeout in milliseconds
# Default: 10000 (10 seconds)
# HTTP_TIMEOUT=10000

# Maximum results to return from search/filter operations
# Default: 10
# MAX_RESULTS=10

# Maximum length for search queries and filter strings
# Default: 50 characters
# MAX_QUERY_LENGTH=50

# Enable debug logging (set to any value to enable)
# Default: false (unset or empty)
# DEBUG=true
